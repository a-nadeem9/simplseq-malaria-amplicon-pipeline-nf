nextflow.enable.dsl = 2

env {
  PATH = "${baseDir}/workflow/bin:${baseDir}/workflow/scripts:${System.getenv('PATH') ?: ''}"
  PYTHONPATH = "${baseDir}/src"
  SIMPLSEQ_NF_HELPERS = "${baseDir}/workflow/bin/simplseq_nf_helpers.py"
  SIMPLSEQ_AMP_PIPELINE = "${baseDir}/workflow/scripts/AmpliconPipeline.py"
  SIMPLSEQ_POSTPROC_DADA2 = "${baseDir}/workflow/scripts/postProc_dada2.R"
  SIMPLSEQ_ASV_TO_CIGAR = "${baseDir}/workflow/scripts/ASV_to_CIGAR.py"
  SIMPLSEQ_BIOLOGICAL_EQUIVALENCE = "${baseDir}/workflow/scripts/biological_equivalence_report.py"
  SIMPLSEQ_DINEMITES_BRIDGE = "${baseDir}/workflow/scripts/simplseq_to_dinemites.R"
  SIMPLSEQ_DINEMITES_RUN = "${baseDir}/workflow/scripts/run_dinemites.R"
  SIMPLSEQ_DCIFER_BRIDGE = "${baseDir}/workflow/scripts/simplseq_to_dcifer.R"
  SIMPLSEQ_DCIFER_RUN = "${baseDir}/workflow/scripts/run_dcifer.R"
}

params {
  project_name = 'SIMPLseq'
  outdir = 'results'
  samples = 'samples.csv'
  dada2_cpus = 8
  postprocess_cpus = 8
  cigar_cpus = 4
  dada2_memory = '12 GB'
  postprocess_memory = '12 GB'
  cigar_memory = '4 GB'

  amplicons_noprimers = 'reference/amplicons_noprimers.fasta'
  snv_filters = 'reference/snv_filters.txt'
  primers_fwd = 'workflow/primers/primers_fwd.fa'
  primers_rev = 'workflow/primers/primers_rev.fa'
  overlap_primers_fwd = 'workflow/primers/overlap_pr1.fa'
  overlap_primers_rev = 'workflow/primers/overlap_pr2.fa'

  pipeline_class = 'parasite'
  save_rdata = 'dada2_run.RData'

  max_ee = '5,5'
  trim_right = '0,0'
  min_len = '50'
  trunc_q = '5,5'
  max_consist = '10'
  omega_a = '1e-120'
  just_concatenate = '0'
  dada2_randomize = '1'
  dada2_multithread = '1'
  dada2_seed = ''

  strict_min_asv_length = 100
  indel_filter = '0.10'

  cigar_homopolymer_mask_length = 5
  cigar_min_total_reads = 100
  cigar_min_samples = 2
  cigar_exclude_bimeras = true

  inline_barcodes_enabled = false
  sentinel_locus = 'KELT'

  validation_frozen_results = ''
  biological_equivalence_thresholds = '1,10,100'
  biological_equivalence_fail_on_fail = true

  // DINEMITES downstream analysis
  dinemites_enabled = false
  dinemites_model = 'simple'
  dinemites_n_lags = 3
  dinemites_t_lag = 'Inf'
  dinemites_seed = 1
  dinemites_refresh = 100
  dinemites_bayesian_lag_days = 30
  dinemites_bayesian_chains = 1
  dinemites_bayesian_parallel_chains = 1
  dinemites_bayesian_iter_warmup = 500
  dinemites_bayesian_iter_sampling = 500
  dinemites_bayesian_adapt_delta = 0.99
  dinemites_bayesian_drop_out = false
  dinemites_min_abundance_pct = 0.3
  dinemites_abundance_denominator = 'locus'
  dinemites_plot_width = 18
  dinemites_plot_height = 0

  // dcifer downstream relatedness analysis
  dcifer_enabled = false
  dcifer_min_abundance_pct = 0.3
  dcifer_abundance_denominator = 'locus'
  dcifer_coi_lrank = 2
  dcifer_ibd_grid_nr = 1000
  dcifer_alpha = 0.05
  dcifer_afreq_mode = 'current_run'
}

process {
  shell = ['/bin/bash', '-euo', 'pipefail']
  executor = 'local'
  errorStrategy = { task.exitStatus in [137, 139, 143] ? 'retry' : 'terminate' }
  maxRetries = 1
}

profiles {
  local {
    process.executor = 'local'
  }

  reproducible {
    params.dada2_randomize = '1'
    params.dada2_multithread = '0'
    params.dada2_seed = '1'
  }
}
